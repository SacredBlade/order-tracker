# =============================================================================
# Copy this file to ".env.local" and fill in the two values from Supabase.
# In Supabase: Project Settings -> Data API  (and  Project Settings -> API Keys)
# These are SAFE to expose in the browser (the "anon" / publishable key).
# Your data is protected by Row Level Security + the login, not by hiding the key.
# =============================================================================

# Looks like: https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The long "anon" / "publishable" key (starts with eyJ... or sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
